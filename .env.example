# DocMind environment variables. Copy to ".env" and fill in.
# NEVER commit a real .env file.

# --- REQUIRED ---
# Groq API key. Used ONLY for final chat response generation.
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# --- OPTIONAL: tunable settings (sensible defaults applied if unset) ---

# Chunking
CHUNK_SIZE_TOKENS=512          # tokens per chunk
CHUNK_OVERLAP_RATIO=0.15       # 15% overlap

# Retrieval
DENSE_TOP_K=25                 # dense vector results
BM25_TOP_K=25                  # keyword results
FUSION_CANDIDATES=50           # max unique candidates after RRF
RERANK_TOP_K=5                 # chunks passed to the LLM

# Upload limits
MAX_FILE_MB=10                 # per-file size cap
MAX_BATCH_MB=100               # total batch size cap
MAX_FILES_PER_BATCH=10         # file count cap

# Models
DEFAULT_MODEL=llama-3.1-8b-instant   # default Groq model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5 # local embedding model
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2 # local FlashRank cross-encoder

# Session expiry
SESSION_TTL_MINUTES=120        # idle session lifetime before cleanup

# Storage (ephemeral on free hosting)
DATA_DIR=.docmind_data         # root for ChromaDB + uploads + indexes

# OCR (Windows: path to tesseract.exe; leave blank if on PATH)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional: enable Docling for complex/scanned PDFs (heavy). Requires requirements-docling.txt
ENABLE_DOCLING=false
